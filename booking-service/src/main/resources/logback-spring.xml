<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── Human-readable for dev / local / default ────────────────────────── -->
    <springProfile name="dev,local,default">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] [cid=%X{correlationId:-none}] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.workshop" level="DEBUG"/>
        <logger name="org.axonframework" level="WARN"/>
        <logger name="org.springframework" level="WARN"/>
    </springProfile>

    <!-- ── Structured JSON for prod ────────────────────────────────────────── -->
    <springProfile name="prod">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"service":"booking-service"}</customFields>
                <includeMdcKeyName>correlationId</includeMdcKeyName>
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>spanId</includeMdcKeyName>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
        <logger name="com.workshop" level="INFO"/>
        <logger name="org.axonframework" level="WARN"/>
        <logger name="org.springframework" level="WARN"/>
    </springProfile>

</configuration>
